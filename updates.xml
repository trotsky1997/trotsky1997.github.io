---
layout: null
permalink: /updates.xml
sitemap: false
---
{% assign updates = site.data.updates | sort: "date" | reverse %}{% assign latest = updates | first %}<feed xmlns="http://www.w3.org/2005/Atom">
  <title>{{ site.title | xml_escape }} Updates</title>
  <subtitle>{{ site.description | xml_escape }}</subtitle>
  <link href="{{ '/updates.xml' | absolute_url }}" rel="self" type="application/atom+xml" />
  <link href="{{ '/updates/' | absolute_url }}" rel="alternate" type="text/html" />
  <id>{{ '/updates/' | absolute_url | xml_escape }}</id>
  <updated>{{ latest.date | date_to_xmlschema }}</updated>
  <author>
    <name>{{ site.author.name | default: site.title | xml_escape }}</name>
    {% if site.author.email %}<email>{{ site.author.email | xml_escape }}</email>{% endif %}
  </author>
  {% for update in updates limit:20 %}
    {% assign target = update.url %}
    {% if target contains "://" %}
      {% assign entry_href = target %}
    {% else %}
      {% assign entry_href = target | absolute_url %}
    {% endif %}
  <entry>
    <title>{{ update.title | xml_escape }}</title>
    <link href="{{ entry_href | xml_escape }}" rel="alternate" />
    <id>{{ '/updates/#' | append: update.id | absolute_url | xml_escape }}</id>
    <updated>{{ update.date | date_to_xmlschema }}</updated>
    <summary type="html">{{ update.summary | xml_escape }}</summary>
    <category term="{{ update.type | xml_escape }}" />
    {% if update.tags %}{% for tag in update.tags %}
    <category term="{{ tag | xml_escape }}" />
    {% endfor %}{% endif %}
  </entry>
  {% endfor %}
</feed>
